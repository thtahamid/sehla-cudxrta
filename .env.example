TOMTOM_API_KEY=

# Mistral AI - powers the autonomous congestion agent (Twin Brain).
# Without MISTRAL_AI_API_KEY the app runs normally; the AI advisory rail shows a
# "copilot not configured" hint and never blocks the dashboard.
MISTRAL_AI_API_KEY=
# Optional. The persistent Mistral Agent used for advisories. If unset, the server
# lazily creates one on first request (POST /v1/agents) and caches it in memory.
MISTRAL_AGENT_ID=
# Optional. Model the agent reasons with. Default: mistral-medium-latest.
MISTRAL_AGENT_MODEL=mistral-medium-latest
